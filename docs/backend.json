{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Stores institutional client information and clearing balances.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "banned", "on_hold"] },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "securityQuestion", "securityAnswer", "createdAt"]
    },
    "BuyOrder": {
      "title": "Buy Protocol Order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "usdtAmount": { "type": "number" },
        "inrAmount": { "type": "number" },
        "paymentMode": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "paymentReceiptUrl": { "type": "string" }
      }
    },
    "SellOrder": {
      "title": "Liquidation Order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "usdtAmount": { "type": "number" },
        "inrAmount": { "type": "number" },
        "paymentMode": { "type": "string" },
        "status": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" }
      }
    },
    "Deposit": {
      "title": "Wallet Credit Protocol",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "network": { "type": "string" },
        "txHash": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Withdrawal": {
      "title": "Wallet Debit Protocol",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "address": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Institutional client profiles."
    },
    "/buyOrders/{id}": {
      "schema": "BuyOrder",
      "description": "History of digital asset acquisition."
    },
    "/sellOrders/{id}": {
      "schema": "SellOrder",
      "description": "History of digital asset liquidation."
    },
    "/deposits/{id}": {
      "schema": "Deposit",
      "description": "Direct wallet credit history."
    },
    "/withdrawals/{id}": {
      "schema": "Withdrawal",
      "description": "Direct wallet debit history."
    }
  }
}