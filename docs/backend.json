
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Stores additional information about a registered user.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "balance": { "type": "number", "description": "The current USDT balance of the user." },
        "status": { "type": "string", "enum": ["active", "banned", "on_hold"], "default": "active" },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "securityQuestion", "securityAnswer", "createdAt"]
    },
    "BuyOrder": {
      "title": "BuyOrder",
      "type": "object",
      "description": "Represents a user's buy order for USDT.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "network": { "type": "string" },
        "usdtAmount": { "type": "number" },
        "inrAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SellOrder": {
      "title": "SellOrder",
      "type": "object",
      "description": "Represents a user's sell order for USDT.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "network": { "type": "string" },
        "usdtAmount": { "type": "number" },
        "inrAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deposit": {
      "title": "USDT Deposit",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Withdrawal": {
      "title": "USDT Withdrawal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/UserProfile" }
        }
      }
    ]
  }
}
