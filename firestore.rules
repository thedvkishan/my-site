
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // For prototyping with mock admin login, we allow broader access to these collections.
    // In a production environment, you would use Firebase Auth Custom Claims or a 'roles' field.
    function isPrototypeAdmin() {
        return true; 
    }

    match /users/{userId} {
      allow read: if true; // Allow admin to see all users for management
      allow write: if isOwner(userId) || isPrototypeAdmin();
    }
    
    match /buyOrders/{orderId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, list: if true;
    }

    match /sellOrders/{orderId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, list: if true;
    }

    match /deposits/{depositId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, list: if true;
    }

    match /withdrawals/{withdrawalId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, list: if true;
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, list: if true;
    }
    
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
