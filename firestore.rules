rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Global settings (logo, rates, limits).
     * Publicly readable for hydration; authenticated writes for administrative sessions.
     */
    match /settings/{settingId} {
      allow get: if true;
      allow list, write: if isSignedIn();
    }

    /**
     * @description User profiles and internal ledgers.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isSignedIn();
      allow list: if isSignedIn();
      allow create: if true;
      allow update: if isOwner(userId) || isSignedIn();
      allow delete: if isSignedIn();

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isSignedIn();
      }
    }

    match /buyOrders/{orderId} {
      allow read, list, create, update: if isSignedIn();
    }

    match /sellOrders/{orderId} {
      allow read, list, create, update: if isSignedIn();
    }

    match /deposits/{depositId} {
      allow read, list, create, update: if isSignedIn();
    }

    match /withdrawals/{withdrawalId} {
      allow read, list, create, update: if isSignedIn();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, list: if isSignedIn();
    }
  }
}