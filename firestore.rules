rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // For prototyping, we are allowing any signed-in user to act as an admin
    // In production, this should check for a custom claim: request.auth.token.isAdmin == true
    function isAdmin() {
        return isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /buyOrders/{orderId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update: if isAdmin() || isOwner(request.resource.data.userId);
        allow list: if isAdmin();
    }

    match /sellOrders/{orderId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update: if isAdmin() || isOwner(request.resource.data.userId);
        allow list: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow list, get: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin(); // Should be restricted to admin in production
    }
  }
}
