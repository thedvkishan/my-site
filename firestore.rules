rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements an administrative-control model for TetherSwap Zone.
     * Security is anchored by a Database-Based Access Control (DBAC) pattern for admins.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        // Temporary allowance for institutional terminal access until role document is provisioned
        // This allows the AdminPower dashboard to function with anonymous auth
        get(/databases/$(database)/documents/settings/appSettings).data.allowPublicSignup != null
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    /**
     * @description Global settings (logo, rates, markup).
     * Publicly readable for the landing page; authenticated-only writes for the terminal.
     */
    match /settings/{settingId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isSignedIn();
    }

    /**
     * @description User profiles and balance clearing.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if true; // Allow initial sign-up
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin() || isOwner(userId);
      }
    }

    /**
     * @description Buy/Sell Orders and Wallet transactions.
     */
    match /buyOrders/{orderId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
    }

    match /sellOrders/{orderId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
    }

    match /deposits/{depositId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
    }

    match /withdrawals/{withdrawalId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
    }

    /**
     * @description Institutional Support Desk.
     */
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, list: if isSignedIn();
    }

    /**
     * @description Admin role ledger.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if false; // System-managed via console
    }
  }
}